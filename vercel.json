{
  "framework": null,
  "outputDirectory": ".",
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/(.*)", "dest": "/api/index.php" },
    { "src": "/((?!assets|public|api|favicon\\.ico).*)", "dest": "/api/entry.php" }
  ]
}
